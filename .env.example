# Database
POSTGRES_PASSWORD=changeme

# AI providers (optional — only needed if using AI cache analysis)
OPENAI_API_KEY=               # API key for OpenAI provider and Custom (OpenAI-compatible) provider
ANTHROPIC_API_KEY=            # API key for Anthropic (Claude) provider
AI_API_BASE_URL=https://chat.netcentric.biz/api  # Base URL for Custom provider (Ollama / LiteLLM / any OpenAI-compatible server)

# Frontend API URL (set this to your backend's public URL)
VITE_API_URL=http://localhost:3001

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Security: set to false only for local testing behind a trusted network
SSRF_PROTECTION=true

# Scan limits
MAX_SCAN_URLS=500
WORKER_REPLICAS=1
WORKER_CONCURRENCY=3

# Timeouts (milliseconds)
BROWSER_TIMEOUT_MS=30000
PROBE_TIMEOUT_MS=15000

# Cache warming
MAX_WARM_ATTEMPTS=5
WARM_DELAY_MS=500
